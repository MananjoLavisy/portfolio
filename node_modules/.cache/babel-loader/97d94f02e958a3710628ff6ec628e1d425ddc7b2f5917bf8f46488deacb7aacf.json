if (savedLang) {\n      setLanguage(savedLang);\n    }\n  }, []);\n\n  useEffect(() => {\n    localStorage.setItem('theme', isDarkMode ? 'dark' : 'light');\n    document.documentElement.setAttribute('data-theme', isDarkMode ? 'dark' : 'light');\n  }, [isDarkMode]);\n\n  useEffect(() => {\n    localStorage.setItem('language', language);\n  }, [language]);\n\n  const toggleTheme = () => setIsDarkMode(!isDarkMode);\n  const toggleLanguage = () => setLanguage(language === 'en' ? 'fr' : 'en');\n\n  return (\n    <ThemeContext.Provider value={{ isDarkMode, toggleTheme, language, toggleLanguage }}>\n      {children}\n    </ThemeContext.Provider>\n  );\n};\n\nexport const useTheme = () => useContext(ThemeContext);\n"],"mappings":"AAAA,MAAO,CAAAA,KAAK,EAAIC,aAAa,CAAEC,QAAQ,CAAEC,SAAS,CAAEC,UAAU,KAAQ,OAAO,CAAC,OAAAC,GAAA,IAAAC,IAAA,yBAE9E,KAAM,CAAAC,YAAY,cAAGN,aAAa,CAAC,CAAC,CAEpC,MAAO,MAAM,CAAAO,aAAa,CAAGC,IAAA,EAAkB,IAAjB,CAAEC,QAAS,CAAC,CAAAD,IAAA,CACxC,KAAM,CAACE,UAAU,CAAEC,aAAa,CAAC,CAAGV,QAAQ,CAAC,IAAI,CAAC,CAClD,KAAM,CAACW,QAAQ,CAAEC,WAAW,CAAC,CAAGZ,QAAQ,CAAC,IAAI,CAAC,CAE9CC,SAAS,CAAC,IAAM,CACd,KAAM,CAAAY,UAAU,CAAGC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC,CAChD,KAAM,CAAAC,SAAS,CAAGF,YAAY,CAACC,OAAO,CAAC,UAAU,CAAC,CAElD,GAAIF,UAAU,CAAE,CACdH,aAAa,CAACG,UAAU,GAAK,MAAM,CAAC,CACtC,CACA,GAAIG,SAAS,CAAE,CACbJ,WAAW,CAACI,SAAS,CAAC,CACxB,CACF,CAAC,CAAE,EAAE,CAAC,CAENf,SAAS,CAAC,IAAM,CACda,YAAY,CAACG,OAAO,CAAC,OAAO,CAAER,UAAU,CAAG,MAAM,CAAG,OAAO,CAAC,CAC5DS,QAAQ,CAACC,eAAe,CAACC,YAAY,CAAC,YAAY,CAAEX,UAAU,CAAG,MAAM,CAAG,OAAO,CAAC,CACpF,CAAC,CAAE,CAACA,UAAU,CAAC,CAAC,CAEhBR,SAAS,CAAC,IAAM,CACda,YAAY,CAACG,OAAO,CAAC,UAAU,CAAEN,QAAQ,CAAC,CAC5C,CAAC,CAAE,CAACA,QAAQ,CAAC,CAAC,CAEd,KAAM,CAAAU,WAAW,CAAGA,CAAA,GAAMX,aAAa,CAAC,CAACD,UAAU,CAAC,CACpD,KAAM,CAAAa,cAAc,CAAGA,CAAA,GAAMV,WAAW,CAACD,QAAQ,GAAK,IAAI,CAAG,IAAI,CAAG,IAAI,CAAC,CAEzE,mBACEP,IAAA,CAACC,YAAY,CAACkB,QAAQ,EAACC,KAAK,CAAE,CAAEf,UAAU,CAAEY,WAAW,CAAEV,QAAQ,CAAEW,cAAe,CAAE,CAAAd,QAAA,CACjFA,QAAQ,CACY,CAAC,CAE5B,CAAC,CAED,MAAO,MAAM,CA